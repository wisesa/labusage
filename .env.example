ADMIN_TOKEN=ganti-dengan-token-admin-yang-kuat
FIRESTORE_USERS_COLLECTION=users

# Pilih salah satu cara credential berikut.

# Opsi 1: file JSON service account di root project.
FIREBASE_CREDENTIALS_FILE=serviceAccountKey.json

# Opsi 2: environment variable untuk deployment.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
